<div class="main-landing page-width">
  {% if section.settings.heading != blank %}
    <h1 class="main-landing__heading">{{ section.settings.heading }}</h1>
  {% endif %}
  {% if section.settings.subtext != blank %}
    <div class="main-landing__subtext rte">{{ section.settings.subtext }}</div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Landing",
  "tag": "section",
  "class": "section-main-landing",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gymshark Style"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Theme connected. Your React/Vite prototype is in the vite-storefront folder for reference while you build Liquid sections."
    }
  ],
  "presets": [
    {
      "name": "Landing"
    }
  ]
}
{% endschema %}
