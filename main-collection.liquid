<div class="main-collection page-width">
  <h1 class="main-collection__title">{{ collection.title }}</h1>
  {% if collection.description != blank %}
    <div class="main-collection__description rte">{{ collection.description }}</div>
  {% endif %}

  <ul class="main-collection__grid">
    {% for product in collection.products %}
      <li class="main-collection__item">
        <a href="{{ product.url }}">{{ product.title }}</a>
      </li>
    {% endfor %}
  </ul>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-main-collection",
  "settings": [],
  "presets": [{ "name": "Collection" }]
}
{% endschema %}
